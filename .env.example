PORT=9999
LOG_DIR=logs
LOG_LEVEL=info
NODE_ENV=development
LOCAL_EXECUTION=false

# MongoDB local sync scaffold
MONGODB_URI=
MONGODB_DB_NAME=

# Local sync ClickUp integration (metrics → ClickUp subtasks)
LOCAL_SYNC_CLICKUP_ENABLED=false
LOCAL_SYNC_CLICKUP_API_TOKEN=
LOCAL_SYNC_CLICKUP_LIST_ID=
LOCAL_SYNC_CLICKUP_PARENT_TASK_ID=

# ClickUp integration
CLICKUP_API_TOKEN=
# Optional (default: https://api.clickup.com/api/v2)
CLICKUP_API_BASE_URL=https://api.clickup.com/api/v2
# Fallback task if no route keyword matches
CLICKUP_DEFAULT_TASK_ID=
# JSON array string of project/client routing rules
CLICKUP_MEETING_ROUTING_JSON=[]
# Optional toggle (default true): create meeting task + subtasks from Groq output
CLICKUP_ENABLE_TASK_CREATION=true
# Optional fallback list id for task/subtask creation (if route.listId is not present)
CLICKUP_TASK_CREATION_LIST_ID=
# Default status for created task/subtasks
CLICKUP_TASK_DEFAULT_STATUS=backlog
# Comma-separated ClickUp user ids to assign parent task + subtasks
# Example: 12345678,87654321
CLICKUP_TASK_ASSIGNEE_IDS=
# Backward-compatible single assignee id
CLICKUP_TEAM_LEAD_USER_ID=

# Groq task extraction
GROQ_API_KEY=
# Optional (default: https://api.groq.com/openai/v1)
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
# Optional (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
# Optional (default: 20000 chars)
GROQ_MAX_TRANSCRIPT_CHARS=20000
# Only subtasks above this confidence are created (all extracted tasks are still logged)
GROQ_TASK_CONFIDENCE_THRESHOLD=0.5

# Optional max chars for parent ClickUp task description (includes transcript)
CLICKUP_MAIN_TASK_DESCRIPTION_MAX_CHARS=50000
